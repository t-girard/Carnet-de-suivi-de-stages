<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA"
    android:layout_marginTop="20dp"
    android:padding="20dp"
    tools:context=".ListCandidaturesActivity">

    <Button
        android:id="@+id/retourSynthese"
        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Synthèse"
        android:textColor="#2D3436"
        android:textSize="20dp"
        android:textStyle="bold"
        app:backgroundTint="@android:color/white"
        app:cornerRadius="12dp"
        app:elevation="4dp"
        app:icon="?attr/homeAsUpIndicator"
        app:iconTint="@android:color/holo_orange_dark"
        app:strokeColor="#DFE6E9"
        app:strokeWidth="1dp" />

    <TextView
        android:id="@+id/titleCandidatures"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Candidatures"
        android:textColor="#2D3436"
        android:textSize="32sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/statsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/txtEnCours"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Candidatures en cours"
            android:textColor="#0984E3"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_weight="1"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">

        <ListView
            android:id="@+id/candidatures"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:divider="#F1F2F6"
            android:dividerHeight="1dp"
            android:padding="8dp"
            tools:listitem="@android:layout/simple_list_item_1" />

    </androidx.cardview.widget.CardView>

</LinearLayout>